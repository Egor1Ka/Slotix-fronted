# ===========================================
# New Relic Monitoring
# ===========================================
# Required: Your New Relic license key (from Account Settings > API keys)
NEW_RELIC_LICENSE_KEY=eu01xxb624133dc24d4d3947a67d23dcFFFFNRAL

# Required: Application name displayed in New Relic dashboard
NEW_RELIC_APP_NAME=Template_App

# Suppress "missing config file" warning when using env-only configuration
NEW_RELIC_NO_CONFIG_FILE=true

# Optional: Explicitly disable NR in environments where keys ARE set (e.g., staging)
# NEW_RELIC_ENABLED=true

# Optional: Logging level (info, debug, trace, warn, error)
# NEW_RELIC_LOG_LEVEL=info

# Optional: Enable/disable distributed tracing (default: true)
# NEW_RELIC_DISTRIBUTED_TRACING_ENABLED=true

# Optional: Enable/disable log forwarding to New Relic (default: true)
# NEW_RELIC_APPLICATION_LOGGING_FORWARDING_ENABLED=true
